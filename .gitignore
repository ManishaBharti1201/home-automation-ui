android/app/build/
android/.gradle/
android/local.properties
android/captures/
.gradle/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Environment Secrets
# Important to keep Tuya credentials and API keys out of source control
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# System/OS Files
.DS_Store
Thumbs.db
*.bak