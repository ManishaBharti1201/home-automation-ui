# Dependencies
node_modules/

# Production Build Artifacts
build/
dist/

# Gateway Dynamic Data
# Excludes the HLS stream segments and ffmpeg logs generated at runtime
# Note: .ts files inside streams/ are video segments, not TypeScript code
gateway/streams/**
gateway/streams/**/*.ts
gateway/*.log

